# Copy this file to .env and fill in real values.
# Never commit .env.

# --- Database ---
DATABASE_URL=postgres://user:pass@localhost:5432/odon
# Supabase shortcut (alternative to DATABASE_URL)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Redis (rate limiting, cron locks, session TTL) ---
REDIS_URL=redis://localhost:6379

# --- Gemini ---
GEMINI_API_KEY=

# --- Google Calendar OAuth (calendar.freebusy scope only by default) ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/oauth/google/callback

# --- Google Maps Places API (venue suggestions) ---
GOOGLE_PLACES_API_KEY=

# --- Token vault (envelope encryption) ---
# Generate with: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=
# Generate with: openssl rand -base64 16
TOKEN_ENCRYPTION_IV=

# --- Telegram adapter (Phase 1) ---
# Get TELEGRAM_BOT_TOKEN from @BotFather (see docs/operations.md).
# TELEGRAM_WEBHOOK_SECRET is yours to pick: any random 1-256 chars from [A-Za-z0-9_-].
# ODON_PUBLIC_URL is where odon-core is publicly reachable (https only).
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
ODON_PUBLIC_URL=

# --- HTTP server ---
PORT=3000
LOG_LEVEL=info
NODE_ENV=development

# --- Short URL host ---
SHORT_URL_BASE=https://odon.gg
